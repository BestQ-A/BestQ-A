{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/observation.schema.json",
  "title": "Observation",
  "type": "object",
  "required": [
    "observation_id",
    "timestamp",
    "facts"
  ],
  "additionalProperties": false,
  "properties": {
    "observation_id": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "context": {
      "type": "object",
      "description": "Structured environment/context key-values (OS, driver, device, version...)",
      "additionalProperties": {
        "type": [
          "string",
          "number",
          "boolean",
          "null"
        ]
      }
    },
    "facts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/Fact"
      }
    },
    "focus_facts": {
      "type": "array",
      "description": "Optional subset of facts to prioritize as 'goals' when explaining. If omitted, the system may use all facts or heuristics.",
      "items": {
        "$ref": "#/$defs/Fact"
      }
    },
    "raw_refs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "URIs or paths to raw logs/metrics artifacts"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "Fact": {
      "title": "Fact",
      "type": "object",
      "required": [
        "pred",
        "value"
      ],
      "additionalProperties": false,
      "properties": {
        "pred": {
          "type": "string",
          "minLength": 1
        },
        "args": {
          "type": "object",
          "description": "Predicate arguments. Values can be concrete or variables like '?x' or wildcard '*'.",
          "default": {},
          "additionalProperties": {
            "type": [
              "string",
              "number",
              "boolean",
              "null"
            ]
          }
        },
        "value": {
          "description": "Fact value (often boolean, but may be string/number/enum).",
          "type": [
            "string",
            "number",
            "boolean",
            "null"
          ]
        }
      }
    }
  }
}